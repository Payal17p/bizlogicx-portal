# MongoDB Atlas Connection (for production)
# Get this from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/bizlogicx?retryWrites=true&w=majority
MONGODB_DB=bizlogicx

# JWT Secret (use a long random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port
PORT=3000

# Optional: WhatsApp number for password reset requests, country code included, digits only
WHATSAPP_SUPPORT_NUMBER=919876543210

# Node Environment
NODE_ENV=development
